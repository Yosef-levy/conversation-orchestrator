# Minimal backend image for dev stack (deps only; source mounted at runtime).
FROM python:3.11-slim

WORKDIR /app
COPY src/backend/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Default command overridden by compose; app code comes from volume mount.
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"]
